{
    "ignores": [
        ".venv",
        ".pytest_cache",
        "node_modules",
        ".next",
        ".git"
    ],
    "config": {
        "default": true,
        "line-length": false,
        "no-trailing-punctuation": false,
        "no-inline-html": false,
        "table-column-style": false,
        "no-duplicate-heading": false
    },
    "overrides": [
        {
            "files": ["CHANGELOG.md"],
            "config": {
                "MD024": false
            }
        }
    ]
}
